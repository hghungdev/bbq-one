{
  "manifest_version": 3,
  "name": "BBQ One",
  "version": "1.0.0",
  "description": "BBQ One — Vintage 1989",
  "icons": {
    "16": "bbq_one-final.png",
    "32": "bbq_one-final.png",
    "48": "bbq_one-final.png",
    "128": "bbq_one-final.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "bbq_one-final.png",
      "32": "bbq_one-final.png",
      "48": "bbq_one-final.png",
      "128": "bbq_one-final.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": ["storage", "identity", "alarms", "clipboardWrite", "bookmarks", "downloads"],
  "host_permissions": ["https://*.supabase.co/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://fonts.googleapis.com"
  }
}
