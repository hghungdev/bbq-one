{
  "manifest_version": 3,
  "name": "BBQ-One",
  "version": "1.1.0",
  "description": "All-in-one: notes, bookmarks, dictionary. Vintage 1989.",
  "icons": {
    "16": "bbq_one-final.png",
    "32": "bbq_one-final.png",
    "48": "bbq_one-final.png",
    "128": "bbq_one-final.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "bbq_one-final.png",
      "32": "bbq_one-final.png",
      "48": "bbq_one-final.png",
      "128": "bbq_one-final.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "storage",
    "contextMenus",
    "identity",
    "alarms",
    "clipboardWrite",
    "scripting",
    "offscreen",
    "bookmarks",
    "downloads",
    "activeTab",
    "tabs"
  ],
  "optional_permissions": [],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://api.dictionaryapi.dev/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "src/content/*", "bbq_one-final.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://fonts.googleapis.com https://api.dictionaryapi.dev"
  }
}
